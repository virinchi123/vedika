generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum EventBookingMode {
  PHONE_IN
  WALK_IN
}

enum CustomerInteractionType {
  WALK_IN
  PHONE_IN
  MISSED_CALL
}

enum FollowupType {
  BOOKING
  SERVICE
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  UPI
}

model User {
  id           String    @id @default(uuid())
  emailAddress String    @unique
  passwordHash String
  phoneNumber  String?   @unique
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  deviceName       String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model File {
  id             String        @id @default(uuid())
  gcsPath        String        @unique
  extension      String
  originalName   String?
  eventBookingId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  callRecords    CallRecord[]
  eventBooking   EventBooking? @relation(fields: [eventBookingId], references: [id], onDelete: SetNull)
  payments       Payment[]
  voiceNotes     VoiceNote[]

  @@index([eventBookingId])
}

model CallRecord {
  id                    String               @id @default(uuid())
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  callerNumber          String
  receiverNumber        String
  fileId                String?
  customerInteractionId String?
  file                  File?                @relation(fields: [fileId], references: [id], onDelete: SetNull)
  customerInteraction   CustomerInteraction? @relation(fields: [customerInteractionId], references: [id], onDelete: SetNull)

  @@index([fileId])
  @@index([customerInteractionId])
}

model ServiceProvider {
  id             String         @id @default(uuid())
  name           String         @unique
  phoneNumber    String?
  email          String?        @unique
  commissionRate Float
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  eventBookings  EventBooking[]
  followups      Followup[]
  services       Service[]
}

model EventType {
  id                          String                       @id @default(uuid())
  createdAt                   DateTime                     @default(now())
  name                        String                       @unique
  updatedAt                   DateTime                     @updatedAt
  eventBookings               EventBooking[]
  defaultBookingConfiguration DefaultBookingConfiguration?
}

model DefaultBookingConfiguration {
  id                       String    @id @default(uuid())
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  eventTypeId              String    @unique
  defaultStartTime         DateTime  @default(dbgenerated("TIME '08:00:00'")) @db.Time
  defaultDurationInMinutes Int       @default(240)
  eventType                EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
}

model EventStatus {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  name          String         @unique
  updatedAt     DateTime       @updatedAt
  eventBookings EventBooking[]
}

model EventBooking {
  id                   String                @id @default(uuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  mode                 EventBookingMode
  eventStatusId        String
  eventTypeId          String
  bookingStart         DateTime
  bookingEnd           DateTime
  muhurat              DateTime?
  customerName         String
  phoneNumber1         String
  phoneNumber2         String?
  phoneNumber3         String?
  referredBy           String?
  eventStatus          EventStatus           @relation(fields: [eventStatusId], references: [id], onDelete: Restrict)
  eventType            EventType             @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  serviceProviders     ServiceProvider[]
  customerInteractions CustomerInteraction[]
  files                File[]
  followups            Followup[]
  services             Service[]
}

model Service {
  id                String          @id @default(uuid())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  serviceProviderId String
  eventBookingId    String
  contractedAmount  Decimal?        @db.Decimal(10, 2)
  customerPaidAmount Decimal?       @db.Decimal(10, 2)
  grossCommission  Decimal?        @db.Decimal(10, 2)
  deduction        Decimal?        @db.Decimal(10, 2)
  commissionPaidAmount Decimal?     @db.Decimal(10, 2)
  payments          Payment[]
  serviceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id], onDelete: Restrict)
  eventBooking      EventBooking    @relation(fields: [eventBookingId], references: [id], onDelete: Cascade)

  @@unique([serviceProviderId, eventBookingId])
  @@index([serviceProviderId])
  @@index([eventBookingId])
}

model Payment {
  id                 String      @id @default(uuid())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  mode               PaymentMode
  amount             Decimal     @db.Decimal(10, 2)
  date               DateTime    @db.Date
  serviceId          String
  paymentProofFileId String?
  service            Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  paymentProofFile   File?       @relation(fields: [paymentProofFileId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([paymentProofFileId])
}

model CustomerInteraction {
  id              String                  @id @default(uuid())
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  interactionType CustomerInteractionType
  occurredAt      DateTime
  ignored         Boolean                 @default(false)
  callRecords     CallRecord[]
  eventBookings   EventBooking[]
  followups       Followup[]
  voiceNote       VoiceNote?
}

model VoiceNote {
  id                    String              @id @default(uuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  fileId                String
  customerInteractionId String              @unique
  file                  File                @relation(fields: [fileId], references: [id], onDelete: Restrict)
  customerInteraction   CustomerInteraction @relation(fields: [customerInteractionId], references: [id], onDelete: Restrict)

  @@index([fileId])
}

model Followup {
  id                    String               @id @default(uuid())
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  dueDate               DateTime
  type                  FollowupType
  description           String?
  eventBookingId        String?
  serviceProviderId     String?
  customerInteractionId String?
  eventBooking          EventBooking?        @relation(fields: [eventBookingId], references: [id], onDelete: Restrict)
  serviceProvider       ServiceProvider?     @relation(fields: [serviceProviderId], references: [id], onDelete: Restrict)
  customerInteraction   CustomerInteraction? @relation(fields: [customerInteractionId], references: [id], onDelete: Restrict)

  @@index([dueDate])
  @@index([type, dueDate])
  @@index([eventBookingId])
  @@index([serviceProviderId])
  @@index([customerInteractionId])
}
