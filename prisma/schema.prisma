generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum EventBookingMode {
  PHONE_IN
  WALK_IN
}

enum CustomerInteractionType {
  WALK_IN
  PHONE_IN
  MISSED_CALL
}

model User {
  id           String    @id @default(uuid())
  emailAddress String    @unique
  passwordHash String
  phoneNumber  String?   @unique
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  deviceName       String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ServiceProvider {
  id            String         @id @default(uuid())
  name          String         @unique
  phoneNumber   String?
  email         String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  eventBookings EventBooking[]
}

model EventType {
  id                          String                       @id @default(uuid())
  createdAt                   DateTime                     @default(now())
  name                        String                       @unique
  updatedAt                   DateTime                     @updatedAt
  eventBookings               EventBooking[]
  defaultBookingConfiguration DefaultBookingConfiguration?
}

model DefaultBookingConfiguration {
  id                       String    @id @default(uuid())
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  eventTypeId              String    @unique
  defaultStartTime         DateTime  @default(dbgenerated("TIME '08:00:00'")) @db.Time
  defaultDurationInMinutes Int       @default(240)
  eventType                EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
}

model EventStatus {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  name          String         @unique
  updatedAt     DateTime       @updatedAt
  eventBookings EventBooking[]
}

model BookingStatus {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  name          String         @unique
  updatedAt     DateTime       @updatedAt
  eventBookings EventBooking[]
}

model EventBooking {
  id                   String                @id @default(uuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  mode                 EventBookingMode
  bookingStatusId      String
  eventStatusId        String
  eventTypeId          String
  bookingStart         DateTime
  bookingEnd           DateTime
  muhurat              DateTime?
  customerName         String
  phoneNumber1         String
  phoneNumber2         String?
  phoneNumber3         String?
  referredBy           String?
  bookingStatus        BookingStatus         @relation(fields: [bookingStatusId], references: [id], onDelete: Restrict)
  eventStatus          EventStatus           @relation(fields: [eventStatusId], references: [id], onDelete: Restrict)
  eventType            EventType             @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  serviceProviders     ServiceProvider[]
  customerInteractions CustomerInteraction[]
}

model CustomerInteraction {
  id              String                  @id @default(uuid())
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  interactionType CustomerInteractionType
  occurredAt      DateTime
  ignored         Boolean                 @default(false)
  eventBookings   EventBooking[]
}
