{
  "name": "vedika",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "yarn prisma:generate",
    "dev": "tsx watch src/server.ts",
    "prebuild": "yarn prisma:generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "pretypecheck": "yarn prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "yarn prisma:generate",
    "test": "NODE_ENV=test TEST_DATABASE_NAME=vedika_test node --import tsx --test tests/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:test": "NODE_ENV=test TEST_DATABASE_NAME=vedika_test prisma migrate deploy",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "express": "^5.1.0",
    "jose": "^6.2.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
